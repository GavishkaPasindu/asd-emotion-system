# Flask / Server
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=False

# CORS — set this to your Vercel frontend URL after deploying
CORS_ORIGINS=https://your-app.vercel.app

# Model directory (Railway uses /app as the working directory)
TRAINED_MODELS_DIR=trained_models

# Max upload size in bytes (16 MB)
MAX_CONTENT_LENGTH=16777216
